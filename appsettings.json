{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "FireWallService.FirewallService": "Debug",
      "FireWallService.PacketCapture": "Information"
    }
  },
  "Firewall": {
    "Filter": "true",
    "Priority": 0,
    "QueueLength": 4096,
    "QueueTime": 2000,
    "QueueSize": 67108864,
    "DefaultAction": "Block",
    "Capture": {
      "Enabled": true,
      "RecordToFile": true,
      "OutputFile": "captures/firewall_capture.pcap",
      "MaxStoredPackets": 10000
    },
    "PacketLog": {
      "Enabled": true,
      "Directory": "logs"
    },
    "NamedPipe": {
      "PipeName": "FireWallServicePipe"
    },
    "Rules": {
      "0": {
        "Name": "Блокировать узел 192.168.1.100 (пример)",
        "Action": "Block",
        "DestinationIP": "192.168.1.100",
        "Description": "Пример: полный запрет обмена с конкретным узлом"
      },
      "1": {
        "Name": "Разрешить ответы DNS",
        "Action": "Allow",
        "Protocol": "17",
        "Direction": "inbound",
        "SourcePort": "53",
        "Description": "Входящие ответы DNS-сервера (порт источника 53)"
      },
      "2": {
        "Name": "Разрешить ответы HTTPS",
        "Action": "Allow",
        "Protocol": "6",
        "Direction": "inbound",
        "SourcePort": "443",
        "Description": "Входящие данные с веб-серверов по TLS (порт источника 443)"
      },
      "3": {
        "Name": "Разрешить ответы HTTP",
        "Action": "Allow",
        "Protocol": "6",
        "Direction": "inbound",
        "SourcePort": "80",
        "Description": "Входящие данные с веб-серверов (порт источника 80)"
      },
      "4": {
        "Name": "Разрешить loopback (входящие)",
        "Action": "Allow",
        "SourceIP": "127.0.0.1",
        "Description": "Локальная петля — обмен внутри хоста"
      },
      "5": {
        "Name": "Разрешить loopback (исходящие)",
        "Action": "Allow",
        "DestinationIP": "127.0.0.1",
        "Description": "Локальная петля — обмен внутри хоста"
      },
      "6": {
        "Name": "Разрешить весь исходящий трафик",
        "Action": "Allow",
        "Direction": "outbound",
        "Description": "Исходящие соединения с этого хоста (запросы в интернет)"
      }
    }
  }
}
